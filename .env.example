# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit secrets.

# ─── MikroTik Routers ────────────────────────────────────────────────────────
# Define up to N routers by incrementing the index.
# ROUTER_1 must be set (CAPsMAN controller). ROUTER_2..N are optional.

# Router 1 — primary (CAPsMAN controller)
MIKROTIK_ROUTER_1_NAME=tplink
MIKROTIK_ROUTER_1_HOST=10.1.0.1
MIKROTIK_ROUTER_1_PORT=443
MIKROTIK_ROUTER_1_SCHEME=https
MIKROTIK_ROUTER_1_USER=mcp-api
MIKROTIK_ROUTER_1_PASS=CHANGE_ME
MIKROTIK_ROUTER_1_TLS_SKIP_VERIFY=true   # set false with a CA-signed cert

# Router 2 — escritorio CAP (remove block if unused)
MIKROTIK_ROUTER_2_NAME=escritorio
MIKROTIK_ROUTER_2_HOST=10.1.0.X
MIKROTIK_ROUTER_2_PORT=443
MIKROTIK_ROUTER_2_SCHEME=https
MIKROTIK_ROUTER_2_USER=mcp-api
MIKROTIK_ROUTER_2_PASS=CHANGE_ME
MIKROTIK_ROUTER_2_TLS_SKIP_VERIFY=true

# Router 3 — suite CAP (remove block if unused)
MIKROTIK_ROUTER_3_NAME=suite
MIKROTIK_ROUTER_3_HOST=10.1.0.3
MIKROTIK_ROUTER_3_PORT=443
MIKROTIK_ROUTER_3_SCHEME=https
MIKROTIK_ROUTER_3_USER=mcp-api
MIKROTIK_ROUTER_3_PASS=CHANGE_ME
MIKROTIK_ROUTER_3_TLS_SKIP_VERIFY=true

# ─── AWS S3 (optional — for backup uploads) ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=my-backup-bucket
AWS_S3_PREFIX=mikrotik-backups/

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Transport: "stdio" for Claude Desktop  |  "http" for remote/API access
MCP_TRANSPORT=stdio

# HTTP transport (only used when MCP_TRANSPORT=http)
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
MCP_AUTH_TOKEN=           # optional Bearer token — openssl rand -hex 32

# Logging
LOG_LEVEL=info            # debug | info | warn | error
